    "helpCenter.helpBypassA" : {
      "extractionState" : "stale",
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Обход VPN позволяет определённым приложениям, сайтам или IP-адресам подключаться напрямую, минуя VPN-туннель. Это полезно для сервисов, блокирующих VPN (банковские приложения), или для доступа к локальной сети."
          }
        }
      }
    },
