    },
    "helpCenter.helpDisconnectA" : {
      "extractionState" : "stale",
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Убедитесь, что у вас стабильное интернет-соединение. Попробуйте другой сервер. Если проблема не исчезает, выйдите из аккаунта и войдите снова для обновления сессии."
          }
        }
      }
    },
    "helpCenter.helpDisconnectQ" : {
      "extractionState" : "stale",
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VPN постоянно отключается. Что делать?"
          }
        }
      }
    },
    "helpCenter.helpEncryptedA" : {
      "extractionState" : "stale",
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Да. Весь трафик между вашим устройством и VPN-сервером шифруется с помощью современной криптографии протокола WireGuard: ChaCha20 для шифрования и Curve25519 для обмена ключами."
          }
        }
      }
    },
    "helpCenter.helpEncryptedQ" : {
      "extractionState" : "stale",
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Мои данные зашифрованы?"
          }
        }
      }
    },
    "helpCenter.helpLatencyA" : {
      "extractionState" : "stale",
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Задержка (в миллисекундах) — время передачи данных между вашим устройством и сервером. Чем меньше — тем лучше: до 50 мс — отлично, 50–100 мс — хорошо, более 100 мс — может ощущаться медленнее."
          }
        }
      }
    },
    "helpCenter.helpLatencyQ" : {
      "extractionState" : "stale",
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Что означает задержка?"
          }
        }
      }
    },
    "helpCenter.helpLogsA" : {
      "extractionState" : "stale",
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нет. VPN Dan не ведёт логи вашей активности, DNS-запросов или трафика. Мы храним только минимум информации, необходимой для работы аккаунта и подключения."
          }
        }
      }
    },
    "helpCenter.helpLogsQ" : {
      "extractionState" : "stale",
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
