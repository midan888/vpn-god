      "extractionState" : "stale",
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Да, для использования VPN Dan необходим аккаунт. Он позволяет безопасно управлять VPN-подключением без хранения данных о вашей активности."
