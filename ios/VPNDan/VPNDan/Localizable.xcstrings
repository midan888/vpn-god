    "helpCenter.helpProtocolA" : {
      "extractionState" : "stale",
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VPN Dan использует WireGuard — современный VPN-протокол, известный скоростью, простотой и надёжным шифрованием. Он быстрее и безопаснее устаревших протоколов OpenVPN и IPSec."
          }
        }
      }
    },
